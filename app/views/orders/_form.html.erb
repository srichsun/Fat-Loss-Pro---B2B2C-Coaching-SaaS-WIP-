<%= form_with(model: order, local: true, class: "space-y-4") do |f| %>
  <%# Critical: Pass the idempotency key to prevent duplicate orders/charges from double submissions %>
  <%= f.hidden_field :idempotency_key %>

  <div>
    <%= f.label :client_id, "Select Client", class: "block font-bold" %>
    <% if params[:client_id] %>
      <%# Context-aware UI: Lock the selection if accessed from a specific client page %>
      <%= f.collection_select :client_id, @clients, :id, :email, { selected: params[:client_id] }, { class: "border p-2 w-full bg-gray-100", disabled: true } %>
      
      <%# Essential: 'disabled' fields are not submitted, so we use a hidden field to pass the value %>
      <%= f.hidden_field :client_id, value: params[:client_id] %>
    <% else %>
      <%# Standard selection for direct order creation %>
      <%= f.collection_select :client_id, @clients, :id, :email, { prompt: "Please select a client" }, { class: "border p-2 w-full" } %>
    <% end %>
  </div>

  <div>
    <%= f.label :amount, "Amount (TWD)", class: "block font-bold" %>
    <%= f.number_field :amount, step: 0.01, class: "border p-2 w-full", placeholder: "e.g. 12000.00" %>
  </div>

  <div>
    <%= f.label :description, "Description", class: "block font-bold" %>
    <%= f.text_area :description, class: "border p-2 w-full", rows: 3 %>
  </div>

  <%= f.submit "Create Order", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
<% end %>