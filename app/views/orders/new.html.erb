<div class="min-h-screen bg-gray-50 pb-12">
  <div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    
    <div class="mb-8">
      <%= link_to orders_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-800 flex items-center gap-1 mb-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Back to Orders
      <% end %>
      <h1 class="text-3xl font-bold text-gray-900">Create New Order</h1>
    </div>

    <div class="bg-white shadow-sm border border-gray-100 rounded-2xl p-8">
      <%= form_with(model: @order, class: "space-y-6") do |f| %>
        
        <%# Critical: Pass the idempotency key to prevent duplicate orders/charges from double submissions %>
        <%= f.hidden_field :idempotency_key %>  

        <% if @order.errors.any? %>
          <div class="bg-red-50 p-4 rounded-xl border border-red-100 mb-6">
            <h2 class="text-sm font-bold text-red-800"><%= pluralize(@order.errors.count, "error") %> prohibited this order from being saved:</h2>
            <ul class="mt-2 text-xs text-red-700 list-disc list-inside">
              <% @order.errors.full_messages.each do |error| %>
                <li><%= error %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :client_id, "Select Client", class: "block text-sm font-bold text-gray-700 mb-1" %>
          
          <% if params[:client_id].present? %>
            <%# Scenario A: Accessed via a specific client from Dashboard; lock the dropdown %>
            <div class="relative">
              <%= f.collection_select :client_id, @clients, :id, :name, {}, 
                  class: "block w-full border-gray-200 bg-gray-50 text-gray-500 rounded-xl shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-3 cursor-not-allowed", 
                  disabled: true %>
              <%# IMPORTANT: Disabled fields are not submitted; a hidden_field is required to pass the value %>
              <%= f.hidden_field :client_id %>
            </div>
            <p class="mt-1 text-xs text-gray-500 italic">Order is pre-assigned to this client.</p>
          <% else %>
            <%# Scenario B: Accessed directly via Orders page; allow free selection %>
            <%= f.collection_select :client_id, @clients, :id, :name, { prompt: "Choose a client..." }, 
                class: "block w-full border-gray-300 rounded-xl shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-3" %>
          <% end %>
        </div>

        <div>
          <%= f.label :amount, "Amount (USD)", class: "block text-sm font-bold text-gray-700 mb-1" %>
          <div class="mt-1 relative rounded-xl shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">$</span>
            </div>
            <%= f.number_field :amount, step: :any, class: "block w-full pl-8 border-gray-300 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-3", placeholder: "0.00" %>
          </div>
        </div>

        <div>
          <%= f.label :description, "Service Description", class: "block text-sm font-bold text-gray-700 mb-1" %>
          <%= f.text_area :description, rows: 3, class: "block w-full border-gray-300 rounded-xl shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-3", placeholder: "e.g. 12-Week Fat Loss Coaching" %>
        </div>

        <div class="pt-4">
          <%= f.submit "Create & Send Order", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none transition-all active:scale-95" %>
        </div>
      <% end %>
    </div>

  </div>
</div>